datasource db {
  provider="postgresql"
  url=env("POSTGRES_PRISMA_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Todo {
  id        String      @id @default(cuid()) @map("_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  label    String?
  done Boolean  @default(false)
}